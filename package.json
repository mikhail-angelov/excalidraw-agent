{
  "name": "excalidraw-agent",
  "version": "1.0.0",
  "description": "AI agent that draws on an Excalidraw canvas",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node src/server.ts",
    "agent": "node src/agent.ts",
    "build:server": "npx tsc",
    "build:ui": "vite build",
    "build": "npm run build:ui && npm run build:server",
    "production": "npm run build && PORT=3000 HOST=0.0.0.0 node dist/server.js",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --ui --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": { "node": ">=18.0.0" },
  "license": "MIT"
}
